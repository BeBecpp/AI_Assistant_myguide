FLASK_ENV=development
PORT=5000

# Optional: enable real AI replies (Gemini preferred)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: multiple keys (comma-separated) for failover / rate-limit smoothing
GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash

# Optional: OpenAI (fallback if GEMINI_API_KEY not set)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
